PORT=5000
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/jobportal?retryWrites=true&w=majority
JWT_SECRET=your_super_secure_jwt_secret_key_minimum_32_characters
NODE_ENV=production

# Cloudinary — required for file uploads (resume, avatar) in production
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional — AI features work without these (smart fallback responses used)
OPENAI_API_KEY=sk-...your-openai-key-here

# Optional — for real GitHub data in Reputation System
GITHUB_TOKEN=ghp_...your-github-token-here
